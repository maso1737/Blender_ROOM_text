{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/principle-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--acid",
      "--bg-0",
      "--bg-1",
      "--black",
      "--body-size",
      "--border",
      "--cell",
      "--code-size",
      "--disp",
      "--fg-1",
      "--fg-2",
      "--fg-3",
      "--fg-accent",
      "--fg-emphasis",
      "--fg-label",
      "--fg-muted",
      "--glow-gold",
      "--glow-ice",
      "--glow-rouge",
      "--gold",
      "--grad-btn",
      "--grad-page",
      "--grad-spot",
      "--grey",
      "--h1-size",
      "--h2-size",
      "--h3-size",
      "--ice",
      "--ink",
      "--jp",
      "--jp-serif",
      "--label-size",
      "--lavender",
      "--magenta",
      "--mono",
      "--neon",
      "--orn",
      "--panel",
      "--panel-2",
      "--r-lg",
      "--r-md",
      "--r-pill",
      "--r-sm",
      "--r-xs",
      "--rouge",
      "--rouge-deep",
      "--shadow-modal",
      "--sp-1",
      "--sp-2",
      "--sp-3",
      "--sp-4",
      "--sp-5",
      "--sp-6",
      "--white"
    ],
    "tokenKinds": {
